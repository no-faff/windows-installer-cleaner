<Window x:Class="InstallerClean.ConfirmMoveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm move"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{x:Static SystemCommands.CloseWindowCommand}"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCancel"/>
    </Window.CommandBindings>

    <Border Background="#0f172a" CornerRadius="16" Padding="32,28"
            MaxWidth="440" MinWidth="320"
            BorderBrush="#334155" BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="MessageText" Foreground="#f8fafc" FontSize="14"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock x:Name="DestinationText" Foreground="#94a3b8" FontSize="12"
                       TextWrapping="Wrap" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PrimaryPill}" Content="Cancel"
                        Click="OnCancel" Margin="0,0,8,0"/>
                <Button Style="{StaticResource AccentPill}" Content="Move"
                        Click="OnMove"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
