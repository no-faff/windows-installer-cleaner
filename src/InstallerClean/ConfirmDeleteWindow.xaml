<Window x:Class="InstallerClean.ConfirmDeleteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm delete"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{StaticResource Base200}" CornerRadius="16" Padding="32,28"
            MaxWidth="400" MinWidth="320"
            BorderBrush="{StaticResource Primary}" BorderThickness="1">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                      Fill="{StaticResource Warning}" Width="16" Height="16" Stretch="Uniform"
                      VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="MessageText" Foreground="#f8fafc" FontSize="14"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock
                       Text="Files will be sent to the Recycle Bin. Use Move instead if you'd like to keep backup copies."
                       Foreground="#94a3b8" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,20"/>
            <TextBlock x:Name="LargeSizeWarning"
                       Text="Large files may be permanently deleted if the Recycle Bin is full."
                       Foreground="{StaticResource Warning}" FontSize="12" TextWrapping="Wrap"
                       Margin="0,-12,0,20" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PrimaryPill}" Content="_Cancel"
                        Click="OnCancel" IsCancel="True" Margin="0,0,8,0"/>
                <Button Content="_Delete" Click="OnDelete"
                        Foreground="#f8fafc" FontSize="14" FontWeight="Medium"
                        Padding="28,8" Height="40" MinWidth="120" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{StaticResource Danger}" CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#7f1d1d"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#6b1a1a"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
