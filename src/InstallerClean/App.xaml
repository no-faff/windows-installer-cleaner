<Application x:Class="InstallerClean.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Poppins font (bundled locally, matching Upscayl) -->
            <FontFamily x:Key="Poppins">pack://application:,,,/Fonts/#Poppins</FontFamily>
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{StaticResource Poppins}"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource Poppins}"/>
            </Style>

            <!-- Read-only TextBox that looks like a TextBlock but is selectable -->
            <Style x:Key="SelectableText" TargetType="TextBox">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="FontFamily" Value="{StaticResource Poppins}"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu>
                            <MenuItem Header="Copy" Command="ApplicationCommands.Copy"/>
                        </ContextMenu>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Upscayl palette (from tailwind.config.js daisyui theme) -->
            <SolidColorBrush x:Key="Base300" Color="#020617"/>   <!-- deepest background -->
            <SolidColorBrush x:Key="Base200" Color="#0f172a"/>   <!-- card / elevated surface -->
            <SolidColorBrush x:Key="Base100" Color="#1e293b"/>   <!-- sidebar-level surface -->
            <SolidColorBrush x:Key="Primary" Color="#334155"/>   <!-- standard button fill -->
            <SolidColorBrush x:Key="Secondary" Color="#4f46e5"/> <!-- CTA / accent button -->
            <SolidColorBrush x:Key="Accent" Color="#6d28d9"/>    <!-- selection highlight -->
            <SolidColorBrush x:Key="Neutral" Color="#475569"/>   <!-- badges, neutral -->
            <SolidColorBrush x:Key="Danger" Color="#991b1b"/>    <!-- destructive -->
            <SolidColorBrush x:Key="Fg" Color="#f8fafc"/>        <!-- foreground text -->
            <SolidColorBrush x:Key="Body" Color="#cbd5e1"/>      <!-- body text (80% base-content) -->
            <SolidColorBrush x:Key="Muted" Color="#94a3b8"/>     <!-- muted text (50% base-content) -->
            <SolidColorBrush x:Key="Dim" Color="#8494a7"/>        <!-- dim text (metadata labels, placeholders) -->
            <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>    <!-- warning / caution -->
            <SolidColorBrush x:Key="Overlay" Color="#80020617"/> <!-- 50% base-300 overlay -->

            <!-- Card style: rounded like Upscayl, no shadows, just tone shift -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Base200}"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

            <Style x:Key="CardNoPad" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Base200}"/>
                <Setter Property="CornerRadius" Value="20"/>
            </Style>

            <!-- Pill buttons: rounded-btn 2rem (32px), h-10 (40px) -->

            <!-- CTA / accent pill (Move, Save) /indigo #4f46e5 -->
            <Style x:Key="AccentPill" TargetType="Button">
                <Setter Property="Foreground" Value="#f8fafc"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="28,8"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#4f46e5" CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#443cc7"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#3b34af"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary pill (Browse, Add, Close) /slate #334155 -->
            <Style x:Key="PrimaryPill" TargetType="Button">
                <Setter Property="Foreground" Value="#f8fafc"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="28,8"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#334155" CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#2b3749"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#232e3d"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Ghost pill (Settings, Refresh, About) /transparent, muted text -->
            <Style x:Key="GhostPill" TargetType="Button">
                <Setter Property="Foreground" Value="#94a3b8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="20,8"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#f8fafc"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground" Value="#cbd5e1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Pill TextBox /rounded input matching Upscayl's input style -->
            <Style x:Key="PillTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="#0f172a"/>
                <Setter Property="Foreground" Value="#f8fafc"/>
                <Setter Property="CaretBrush" Value="#f8fafc"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    CornerRadius="20">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Dark selection for ListView items (overrides wpfui white/blue highlight) -->
            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="#f8fafc"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="Bd" Background="Transparent" Padding="4,6">
                                <GridViewRowPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1e293b"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark selection for ListBox items (overrides wpfui white/blue highlight) -->
            <Style TargetType="ListBoxItem">
                <Setter Property="Foreground" Value="#f8fafc"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="Transparent" Padding="2,2">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1e293b"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark GridViewColumnHeader (overrides wpfui white header) -->
            <Style TargetType="GridViewColumnHeader">
                <Setter Property="Foreground" Value="#94a3b8"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Border Background="Transparent" Padding="8,6" BorderThickness="0,0,0,1"
                                    BorderBrush="#1e293b">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Link button (details..., text-only, coloured like a hyperlink) -->
            <Style x:Key="LinkButton" TargetType="Button">
                <Setter Property="Foreground" Value="#818cf8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="Tx" Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       VerticalAlignment="Center"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Tx" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Tx" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Upscayl-style thin scrollbar: 8px, rounded, subtle thumb -->
            <Style x:Key="ThinThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="Bg" Background="#33f8fafc" CornerRadius="4"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#80f8fafc"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#80f8fafc"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="MinWidth" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent" CornerRadius="4" Padding="0,28,0,22">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ThinThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="8"/>
                        <Setter Property="MinHeight" Value="8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Border Background="Transparent" CornerRadius="4" Padding="12,0,12,0">
                                        <Track x:Name="PART_Track">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ThinThumb}"/>
                                            </Track.Thumb>
                                        </Track>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Caption button (title bar minimise) -->
            <Style x:Key="CaptionButton" TargetType="Button">
                <Setter Property="Foreground" Value="#94a3b8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#334155"/>
                                    <Setter Property="Foreground" Value="#f8fafc"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#475569"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#334155"/>
                                    <Setter Property="Foreground" Value="#f8fafc"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Caption close button (red on hover) -->
            <Style x:Key="CaptionCloseButton" TargetType="Button">
                <Setter Property="Foreground" Value="#94a3b8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#c0392b"/>
                                    <Setter Property="Foreground" Value="#f8fafc"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#a93226"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#c0392b"/>
                                    <Setter Property="Foreground" Value="#f8fafc"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Tooltip (Upscayl-style: indigo bg, slight rounding) -->
            <Style x:Key="WarningTooltip" TargetType="ToolTip">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="MaxWidth" Value="280"/>
                <Setter Property="Placement" Value="Top"/>
                <Setter Property="HasDropShadow" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <Border Background="#4f46e5" CornerRadius="4"
                                    Padding="10,6">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="#f8fafc" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
