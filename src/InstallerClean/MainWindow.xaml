<Window x:Class="InstallerClean.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InstallerClean"
        Width="720" Height="480"
        MinWidth="520" MinHeight="400"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Base100}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ScanCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="12,0,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0"/>
            <TextBlock Text="InstallerClean" Foreground="#cbd5e1"
                       FontSize="14" FontWeight="Medium"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button Style="{StaticResource CaptionButton}" Content="&#x2015;"
                    Click="MinimizeClick" AutomationProperties.Name="Minimise"/>
            <Button Style="{StaticResource CaptionCloseButton}" Content="&#x2715;"
                    Click="CloseClick" AutomationProperties.Name="Close"/>
        </StackPanel>

        <Grid Grid.Row="1" Grid.RowSpan="2" Margin="24,0,24,48" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Context: scan results ──────────────────────── -->
            <StackPanel Grid.Row="0">

                <!-- Explanatory text -->
                <TextBlock TextWrapping="Wrap" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,16"
                           Text="C:\Windows\Installer contains cached files used by Windows to repair and update software. Orphaned files are no longer needed by any installed product. Superseded patches have been replaced by newer updates. Both are safe to move or delete to free up space."/>

                <!-- Pending reboot warning (Phosphor fill, tweaked !) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18"
                            Visibility="{Binding HasPendingReboot, Converter={StaticResource BoolToVis}}">
                    <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                          Fill="{StaticResource Warning}" Width="16" Height="16" Stretch="Uniform"
                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Windows has pending updates. Restart before moving or deleting files."
                               Foreground="#cbd5e1" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Still used -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#94a3b8" FontSize="14"
                               Text="{Binding RegisteredSummaryText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RegisteredSizeDisplay}"
                               Foreground="#94a3b8" FontSize="14"
                               VerticalAlignment="Center" MinWidth="72" TextAlignment="Right"
                               Margin="12,0"/>
                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource GhostPill}"
                            Content="Details" Command="{Binding OpenRegisteredDetailsCommand}"
                            Height="28" Padding="12,0" FontSize="14"
                            VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>

            </StackPanel>

            <!-- ── Separator ────────────────────────────────────── -->
            <Border Grid.Row="2" BorderBrush="#334155" BorderThickness="0,1,0,0"/>

            <!-- ── Action zone: orphaned + move/delete ──────────── -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Orphaned -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#f8fafc" FontSize="14"
                               Text="{Binding OrphanedSummaryText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding OrphanedSizeDisplay}"
                               Foreground="#f8fafc" FontSize="14"
                               VerticalAlignment="Center" MinWidth="72" TextAlignment="Right"
                               Margin="12,0"/>
                    <Button Grid.Column="2" Style="{StaticResource GhostPill}"
                            Content="Details" Command="{Binding OpenOrphanedDetailsCommand}"
                            Height="28" Padding="12,0" FontSize="14"
                            VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>

                <!-- Move location label -->
                <TextBlock Grid.Row="2" Text="MOVE LOCATION"
                           Foreground="#cbd5e1" FontSize="14"/>

                <!-- Move destination -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox Style="{StaticResource PillTextBox}"
                                 Text="{Binding MoveDestination, Mode=OneWay}"
                                 IsReadOnly="True"/>
                        <TextBlock Text="Move destination..."
                                   Foreground="{StaticResource Dim}" FontSize="12" FontStyle="Italic"
                                   Padding="16,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MoveDestination}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="2" Style="{StaticResource PrimaryPill}"
                            Content="_Browse..." Command="{Binding BrowseDestinationCommand}"/>
                </Grid>

                <!-- Buttons row -->
                <DockPanel Grid.Row="6">
                    <Button DockPanel.Dock="Right" Style="{StaticResource AccentPill}"
                            Content="_Move" Command="{Binding MoveAllCommand}"/>

                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryPill}"
                            Content="_Delete" Command="{Binding DeleteAllCommand}"
                            Margin="0,0,8,0"/>

                    <TextBlock DockPanel.Dock="Left" Text="{Binding OperationProgress}"
                               VerticalAlignment="Center" Foreground="#94a3b8"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Grid>

        </Grid>

        <!-- ── Bottom nav ────────────────────────────────────── -->
        <DockPanel Grid.Row="3" LastChildFill="False" Margin="4,8,24,8">
            <Button DockPanel.Dock="Left" Style="{StaticResource GhostPill}"
                    Content="_Re-scan" Command="{Binding RefreshCommand}"/>
            <Button DockPanel.Dock="Left" Style="{StaticResource GhostPill}"
                    Content="_About" Command="{Binding ShowAboutCommand}" Margin="4,0,0,0"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostPill}"
                    Command="{Binding DonateCommand}"
                    AutomationProperties.Name="Buy me a cuppa on Ko-fi"
                    ToolTipService.InitialShowDelay="0"
                    Padding="6,0" Height="28">
                <Image Source="Assets/kofi-cup.png" Width="21" Height="21"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource WarningTooltip}" Content="Buy me a cuppa"/>
                </Button.ToolTip>
            </Button>
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostPill}"
                    Command="{Binding StarOnGitHubCommand}"
                    AutomationProperties.Name="Leave a star on GitHub"
                    ToolTipService.InitialShowDelay="0"
                    Padding="6,0" Height="28" Margin="0,0,12,0">
                <Path Data="m12.672.668 3.059 6.197 6.838.993a.75.75 0 0 1 .416 1.28l-4.948 4.823 1.168 6.812a.75.75 0 0 1-1.088.79L12 18.347l-6.116 3.216a.75.75 0 0 1-1.088-.791l1.168-6.811-4.948-4.823a.749.749 0 0 1 .416-1.279l6.838-.994L11.327.668a.75.75 0 0 1 1.345 0Z"
                      Fill="{StaticResource Warning}" Width="18" Height="18" Stretch="Uniform"/>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource WarningTooltip}" Content="Leave a star on GitHub"
                             Placement="Left"/>
                </Button.ToolTip>
            </Button>
        </DockPanel>

        <!-- ── Scanning overlay ──────────────────────────────────── -->
        <Grid Grid.RowSpan="4" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="{StaticResource Overlay}"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="8" Margin="0,0,0,12"
                             AutomationProperties.Name="Scanning progress"/>
                <TextBlock Text="{Binding ScanProgress}" Foreground="#f8fafc"
                           FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ── Operating overlay ─────────────────────────────────── -->
        <Grid Grid.RowSpan="4" Visibility="{Binding IsOperating, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="{StaticResource Overlay}"/>
            <Border Background="{StaticResource Base200}" CornerRadius="20"
                    Padding="28,22" MinWidth="260"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding OperationProgress}" Foreground="#f8fafc"
                               FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <ProgressBar Value="{Binding OperationProgressPercent}"
                                 Minimum="0" Maximum="100"
                                 Width="200" Height="8" Margin="0,0,0,8"
                                 AutomationProperties.Name="Operation progress"/>
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource Dim}" FontSize="11">
                            <Run Text="{Binding OperationProgressPercent, Mode=OneWay, StringFormat='{}{0:F0}%'}"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Dim}" FontSize="11">
                            <Run Text="{Binding OperationCurrentFile, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{Binding OperationTotalFiles, Mode=OneWay}"/>
                            <Run Text=" files"/>
                        </TextBlock>
                    </DockPanel>
                    <Button x:Name="OperationCancelButton" Style="{StaticResource GhostPill}" Content="Cancel"
                            Command="{Binding CancelOperationCommand}"
                            HorizontalAlignment="Center" Margin="0,10,0,0"
                            Height="28" Padding="16,0" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>
        <!-- ── Completion overlay ────────────────────────────────── -->
        <Grid x:Name="CompletionOverlay" Grid.RowSpan="4" Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}">
            <Border Background="{StaticResource Base200}" CornerRadius="20"
                    Padding="36,32" MinWidth="340" MaxWidth="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Icon -->
                    <Image Source="Assets/splash-icon.png"
                           Width="64" Height="64" HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,16"/>

                    <!-- Heading -->
                    <TextBlock Text="{Binding CompletionHeading}"
                               Foreground="#4ade80" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <!-- Summary -->
                    <TextBlock Text="{Binding CompletionSummary}"
                               Foreground="#cbd5e1" FontSize="14"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <!-- Restore guidance -->
                    <TextBlock Text="{Binding CompletionRestore}"
                               Foreground="#94a3b8" FontSize="12"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,0,24"/>

                    <!-- Error details (only visible when there are errors) -->
                    <Border Margin="0,0,0,24" MaxHeight="80">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompletionErrors}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox Text="{Binding CompletionErrors, Mode=OneWay}"
                                 Style="{StaticResource SelectableText}"
                                 Foreground="{StaticResource Warning}" FontSize="11"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <!-- Close button -->
                    <Button x:Name="CompletionCloseButton" Style="{StaticResource AccentPill}"
                            Content="Close" Command="{Binding CloseAppCommand}"
                            HorizontalAlignment="Center" MinWidth="120"
                            Margin="0,0,0,8"/>

                    <!-- Run again -->
                    <Button Style="{StaticResource GhostPill}"
                            Content="Run again" Command="{Binding DismissCompletionCommand}"
                            HorizontalAlignment="Center"
                            Height="28" Padding="16,0" FontSize="12"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
