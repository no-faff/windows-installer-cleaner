<Window x:Class="InstallerClean.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Width="420" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Base100}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SubtleLink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#f8fafc"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24,4,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="-8,0,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0"/>
            <TextBlock Text="About" Foreground="#cbd5e1"
                       FontSize="14" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#x2715;"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,-4,-24,0"/>

        <TextBlock Grid.Row="1" Text="InstallerClean"
                   Foreground="#f8fafc" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
        <TextBox Grid.Row="3" x:Name="VersionText"
                 Style="{StaticResource SelectableText}" Foreground="#cbd5e1" FontSize="12"/>
        <TextBlock Grid.Row="5" Foreground="#94a3b8" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff/InstallerClean/blob/main/LICENSE"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">MIT licence</Hyperlink>
        </TextBlock>
        <TextBlock Grid.Row="7" Foreground="#94a3b8" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">github.com/no-faff</Hyperlink>
        </TextBlock>
        <Button Grid.Row="9" Style="{StaticResource PrimaryPill}"
                Content="Close" IsCancel="True" HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="9" HorizontalAlignment="Left"
                   VerticalAlignment="Center" Foreground="#94a3b8" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff/InstallerClean/discussions"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">Send feedback</Hyperlink>
        </TextBlock>
    </Grid>
</Window>
