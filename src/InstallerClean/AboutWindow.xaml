<Window x:Class="InstallerClean.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Width="420" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Base100}">

    <Window.Resources>
        <Style x:Key="SubtleLink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#f8fafc"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="InstallerClean"
                   Foreground="#f8fafc" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="2" x:Name="VersionText"
                   Foreground="#cbd5e1" FontSize="12"/>
        <TextBlock Grid.Row="4" Foreground="#94a3b8" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff/windows-installer-cleaner/blob/main/LICENSE"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">MIT licence</Hyperlink>
        </TextBlock>
        <TextBlock Grid.Row="6" Foreground="#94a3b8" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">github.com/no-faff</Hyperlink>
        </TextBlock>
        <Button Grid.Row="8" Style="{StaticResource PrimaryPill}"
                Content="Close" IsCancel="True" HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="8" HorizontalAlignment="Left"
                   VerticalAlignment="Center" Foreground="#94a3b8" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff/windows-installer-cleaner/discussions"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">Send feedback</Hyperlink>
        </TextBlock>
    </Grid>
</Window>
