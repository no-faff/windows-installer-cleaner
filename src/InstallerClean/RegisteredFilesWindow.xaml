<Window x:Class="InstallerClean.RegisteredFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:InstallerClean.Converters"
        Title="Registered files"
        Width="950" Height="680"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Base100}"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:CommaToNewlineConverter x:Key="CommaToNewline"/>
    </Window.Resources>

    <Grid Margin="24,4,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
            <RowDefinition Height="2*"/><RowDefinition Height="20"/>
            <RowDefinition Height="3*"/><RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Top" Margin="-8,8,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0"/>
            <TextBlock Text="Registered files" Foreground="#cbd5e1"
                       FontSize="14" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#x2715;"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,-4,-24,0" AutomationProperties.Name="Close"/>

        <TextBlock Grid.Row="1" Text="PRODUCTS" Foreground="#cbd5e1"
                   FontSize="14"/>

        <Border Grid.Row="3" Style="{StaticResource CardNoPad}" ClipToBounds="True">
            <ListView x:Name="ProductsList" ItemsSource="{Binding Products}"
                      GridViewColumnHeader.Click="ColumnHeader_Click"
                      SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                      BorderThickness="0" Background="Transparent"
                      Padding="0" Margin="0,-1,0,-6"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Product name" Width="520">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProductName}" Foreground="#f8fafc"
                                               FontSize="14" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding ProductName}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="File" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" Foreground="#cbd5e1"
                                               FontSize="12" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullPath}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Size" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeDisplay}" Foreground="#cbd5e1"
                                               FontSize="12" TextAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Patches" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PatchCount}" Foreground="#cbd5e1"
                                               FontSize="12" TextAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="PATCHES" Foreground="#cbd5e1"
                           FontSize="14"/>
                <Border Grid.Row="2" Style="{StaticResource CardNoPad}">
                    <Grid>
                        <TextBlock Text="(none)" Foreground="{StaticResource Dim}" FontSize="12"
                                   FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPatches}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox ItemsSource="{Binding SelectedPatches}"
                                 BorderThickness="0" Background="Transparent"
                                 Padding="12,10" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPatches}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <TextBlock Text="{Binding FileName}" Foreground="#f8fafc"
                                                   FontSize="14" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FullPath}"/>
                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="{StaticResource Dim}" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="PRODUCT DETAILS" Foreground="#cbd5e1"
                           FontSize="14"/>
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <TextBlock Text="Select a product to view details."
                                   Foreground="{StaticResource Dim}" FontSize="12" FontStyle="Italic"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="No metadata available."
                                   Foreground="{StaticResource Dim}" FontSize="12" FontStyle="Italic"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Visibility="{Binding ShowNoMetadata, Converter={StaticResource BoolToVis}}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Author" Foreground="{StaticResource Dim}" FontSize="11"/>
                                <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding SelectedDetails.Author, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Title" Foreground="{StaticResource Dim}" FontSize="11"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedDetails.Title, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Subject" Foreground="{StaticResource Dim}" FontSize="11"/>
                                <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding SelectedDetails.Subject, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Digital signature" Foreground="{StaticResource Dim}" FontSize="11"/>
                                <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding SelectedDetails.DigitalSignature, Converter={StaticResource CommaToNewline}, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="File size" Foreground="{StaticResource Dim}" FontSize="11"/>
                                <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding SelectedProduct.SizeDisplay, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12"/>
                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Comment" Foreground="{StaticResource Dim}" FontSize="11"/>
                                <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding SelectedDetails.Comments, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <DockPanel Grid.Row="7" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" Text="{Binding Summary}"
                       Foreground="#cbd5e1" FontSize="12" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryPill}"
                    Content="Close" IsCancel="True"/>
        </DockPanel>
    </Grid>
</Window>
