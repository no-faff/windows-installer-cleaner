<Window x:Class="InstallerClean.OrphanedFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:InstallerClean.Converters"
        Title="Files to clean up"
        Width="920" Height="540"
        MinWidth="600" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Base100}"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:CommaToNewlineConverter x:Key="CommaToNewline"/>
    </Window.Resources>

    <Grid Margin="24,4,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="-8,0,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0"/>
            <TextBlock Text="Files to clean up" Foreground="#cbd5e1"
                       FontSize="14" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#x2715;"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,-4,-24,0" AutomationProperties.Name="Close"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardNoPad}">
                <ListBox x:Name="FilesList" ItemsSource="{Binding Files}"
                         SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Margin="14,10,0,10" HorizontalContentAlignment="Stretch"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1,14,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="72"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding FileName}"
                                           Foreground="#f8fafc" FontSize="14"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Reason}"
                                           Foreground="{StaticResource Dim}" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                           Foreground="#cbd5e1" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <TextBlock Text="Select a file to view details."
                               Foreground="{StaticResource Dim}" FontSize="12" FontStyle="Italic"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="No metadata available."
                               Foreground="{StaticResource Dim}" FontSize="12" FontStyle="Italic"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Visibility="{Binding ShowNoMetadata, Converter={StaticResource BoolToVis}}"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Reason" Foreground="{StaticResource Dim}" FontSize="11"/>
                            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding SelectedFile.Reason, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Author" Foreground="{StaticResource Dim}" FontSize="11"/>
                            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedDetails.Author, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Title" Foreground="{StaticResource Dim}" FontSize="11"/>
                            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding SelectedDetails.Title, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Subject" Foreground="{StaticResource Dim}" FontSize="11"/>
                            <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding SelectedDetails.Subject, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Digital signature" Foreground="{StaticResource Dim}" FontSize="11"/>
                            <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding SelectedDetails.DigitalSignature, Converter={StaticResource CommaToNewline}, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="File size" Foreground="{StaticResource Dim}" FontSize="11"/>
                            <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding SelectedFile.SizeDisplay, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12"/>
                            <TextBlock Grid.Row="12" Grid.Column="0" Text="Comment" Foreground="{StaticResource Dim}" FontSize="11"/>
                            <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding SelectedDetails.Comments, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="#f8fafc" FontSize="12" TextWrapping="Wrap"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" Text="{Binding Summary}"
                       Foreground="#cbd5e1" FontSize="12" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryPill}"
                    Content="Close" IsCancel="True"/>
        </DockPanel>
    </Grid>
</Window>
