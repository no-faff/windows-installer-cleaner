<Window x:Class="InstallerClean.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InstallerClean"
        Width="480" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="#1e293b" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>     <!-- top spacer -->
                <RowDefinition Height="Auto"/>  <!-- icon -->
                <RowDefinition Height="16"/>    <!-- gap -->
                <RowDefinition Height="Auto"/>  <!-- app name -->
                <RowDefinition Height="28"/>    <!-- gap -->
                <RowDefinition Height="Auto"/>  <!-- progress bar -->
                <RowDefinition Height="8"/>     <!-- gap -->
                <RowDefinition Height="Auto"/>  <!-- step text -->
                <RowDefinition Height="*"/>     <!-- bottom spacer -->
            </Grid.RowDefinitions>

            <!-- Icon (centred hero) -->
            <Image Grid.Row="1" Source="Assets/splash-icon.png"
                   Width="96" Height="96"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- App name -->
            <TextBlock Grid.Row="3" Text="InstallerClean"
                       Foreground="#f8fafc"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <!-- Progress bar -->
            <Border Grid.Row="5" CornerRadius="12" Background="#0f172a"
                    Height="20" Margin="48,0">
                <Border x:Name="SplashProgressBorder" CornerRadius="12"
                        HorizontalAlignment="Left" Width="0"
                        Background="#4f46e5"/>
            </Border>
            <!-- Step text -->
            <TextBlock Grid.Row="7"
                       x:Name="StepText"
                       Text="Scanning..."
                       Foreground="#cbd5e1"
                       FontSize="12"
                       HorizontalAlignment="Center"/>

            <!-- Version (bottom right, overlaid) -->
            <TextBlock Grid.Row="8"
                       x:Name="VersionText"
                       Foreground="#64748b"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,20,12"/>
        </Grid>
    </Border>
</Window>
